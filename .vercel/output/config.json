{
	"version": 3,
	"routes": [
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_image$",
			"dest": "_render"
		},
		{
			"src": "^\\/404\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/about\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/career\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/contact\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/content\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/hobbies\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/newsletter\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/now\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/os\\/dashboard\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/privacy\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/projects\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/work\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/writing\\/ai\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/writing\\/food\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/writing\\/product\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/writing\\/sports\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/writing\\/([^/]+?)\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/writing\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/$",
			"dest": "_render"
		},
		{
			"src": "/.*",
			"dest": "_render",
			"status": 404
		}
	]
}