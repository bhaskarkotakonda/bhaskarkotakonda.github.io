---
/**
 * Navbar.astro — Server-rendered top navigation bar.
 *
 * Features:
 *   - Desktop: horizontal link list + site logo
 *   - Mobile: collapsible hamburger menu (JS-free CSS toggle could be added)
 *   - Active-link highlighting based on current URL pathname
 *
 * The nav links array below is the single source of truth for site nav.
 */
interface NavLink {
  href: string;
  label: string;
  dropdown?: { href: string; label: string }[];
}

const navLinks: NavLink[] = [
  { href: '/about', label: 'About' },
  { href: '/career', label: 'Career' },
  { href: '/projects', label: 'Projects' },
  { href: '/writing', label: 'Blog' },
  { href: '/newsletter', label: 'Newsletter' },
  { href: '/hobbies', label: 'Hobbies' },
  { href: '/content', label: 'Recommended Content' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-os-white/80 backdrop-blur-md border-b border-os-light">
  <nav class="container-content">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a 
        href="/" 
        class="text-xl font-bold text-os-black no-underline hover:text-os-accent transition-colors"
      >
        Bhaskar Kotakonda
      </a>
      
      <!-- Desktop Navigation -->
      <ul class="hidden md:flex items-center space-x-6">
        {navLinks.map((link) => (
          <li class={link.dropdown ? 'relative group' : ''}>
            {link.dropdown ? (
              <>
                <button
                  class:list={[
                    'text-sm font-medium transition-colors flex items-center gap-1',
                    currentPath.startsWith(link.href)
                      ? 'text-os-black'
                      : 'text-os-muted hover:text-os-accent',
                  ]}
                >
                  {link.label}
                  <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                  {currentPath.startsWith(link.href) && (
                    <span class="absolute bottom-0 left-0 right-0 h-0.5 bg-os-accent"></span>
                  )}
                </button>
                <ul class="absolute left-0 top-full mt-2 py-2 bg-os-white border border-os-light rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all min-w-[120px] z-50">
                  <li>
                    <a
                      href={link.href}
                      class="block px-4 py-2 text-sm text-os-muted hover:text-os-accent hover:bg-os-light/50 no-underline"
                    >
                      All {link.label}
                    </a>
                  </li>
                  {link.dropdown.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class:list={[
                          'block px-4 py-2 text-sm no-underline hover:bg-os-light/50',
                          currentPath === item.href ? 'text-os-black font-medium' : 'text-os-muted hover:text-os-accent',
                        ]}
                      >
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a
                href={link.href}
                class:list={[
                  'text-sm font-medium no-underline transition-colors relative',
                  currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                    ? 'text-os-black'
                    : 'text-os-muted hover:text-os-accent',
                ]}
              >
                {link.label}
                {(currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))) && (
                  <span class="block h-0.5 bg-os-accent mt-1"></span>
                )}
              </a>
            )}
          </li>
        ))}
      </ul>
      
      <!-- Mobile Menu Button - Just show Personal link on mobile -->
      <a
        href="/personal"
        class="md:hidden px-4 py-2 bg-os-accent text-os-black text-sm font-medium rounded-lg no-underline"
      >
        Personal
      </a>
    </div>
  </nav>
</header>
