---
import OSLayout from './OSLayout.astro';

interface Props {
  title: string;
  description?: string;
  icon?: string;
}

const { title, description, icon = '📋' } = Astro.props;
---

<OSLayout title={title}>
  <header class="mb-6 pt-8 md:pt-0">
    <div class="flex items-center gap-3 mb-1">
      <span class="text-2xl">{icon}</span>
      <h1 class="text-3xl font-bold">{title}</h1>
    </div>
    {description && <p class="text-os-muted">{description}</p>}
  </header>

  <slot name="filters" />

  <div class="bg-os-white border border-os-light rounded-lg overflow-hidden">
    <slot />
  </div>

  <slot name="footer" />
</OSLayout>
