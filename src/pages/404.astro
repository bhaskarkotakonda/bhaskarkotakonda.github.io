---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <section class="container-narrow py-24 md:py-32 text-center">
    <h1 class="text-8xl font-extrabold text-os-accent mb-4">404</h1>
    <h2 class="text-2xl font-bold mb-4">Page Not Found</h2>
    <p class="text-os-muted mb-8">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a href="/personal-os/" class="btn-primary">
      Go Home
    </a>
  </section>
</BaseLayout>
