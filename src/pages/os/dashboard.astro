---
import "../../styles/global.css";
import { UserButton } from "@clerk/astro/components";
import { getSupabaseAdmin } from "../../os/lib/supabase";
import OsProcessButton from "../../components/OsProcessButton";

const supabase = getSupabaseAdmin();

// Fetch Pending Queue Count
const { count: pendingCount } = await supabase
  .from("Raw_Inbox")
  .select("*", { count: 'exact', head: true })
  .eq("processing_status", "pending");

// Fetch Most Important Recent Nodes
const { data: recentNodes } = await supabase
  .from("Processed_Nodes")
  .select("*")
  .gte("importance_score", 6)
  .order("created_at", { ascending: false })
  .limit(6);
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>OS Command Center</title>
  </head>
  <body class="bg-[#0b0c10] text-[#c5c6c7] min-h-screen font-sans selection:bg-[#66fcf1] selection:text-black">
    <div class="max-w-5xl mx-auto px-6 py-12">
      <header class="flex justify-between items-center mb-16 border-b border-[#1f2833] pb-6">
        <div>
          <h1 class="text-3xl md:text-5xl font-black tracking-tight text-white mb-2">Command Center</h1>
          <p class="text-sm md:text-base text-gray-400 font-medium">Your personalized knowledge ingestion pipeline.</p>
        </div>
        <div class="flex items-center gap-6">
          <a href="/os/library" class="text-sm font-bold text-gray-500 hover:text-[#66fcf1] transition uppercase tracking-wider hidden md:block">Go to Library &rarr;</a>
          <UserButton />
        </div>
      </header>
      
      <main class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        
        {/* Left Col: Queue Status */}
        <div class="lg:col-span-1 border-gray-800">
          <div class="bg-[#1f2833]/20 p-8 rounded-3xl border border-[#1f2833] shadow-2xl relative overflow-hidden group hover:border-[#45a29e]/30 transition-all duration-500">
            <div class="absolute -top-10 -right-10 w-40 h-40 bg-[#45a29e] rounded-full blur-[90px] opacity-10 group-hover:opacity-30 transition-opacity duration-700"></div>
            <h2 class="text-xl font-bold text-white mb-2">Queue Status</h2>
            <p class="text-sm text-gray-400 mb-8 font-medium">Items awaiting AI synthesis.</p>
            
            <div class="flex items-center gap-5 mb-6">
              <span class="text-7xl font-black text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-400 drop-shadow-sm">{pendingCount || 0}</span> 
              <span class="text-[11px] text-[#45a29e] uppercase tracking-[0.2em] font-bold leading-tight">Pending<br/>Items In<br/>Inbox</span>
            </div>
            
            <OsProcessButton client:load pendingCount={pendingCount || 0} />
          </div>
          <div class="mt-8 text-center md:text-left">
             <a href="/os/library" class="text-xs font-bold text-[#66fcf1] hover:text-white transition uppercase tracking-widest md:hidden">Browse Database &rarr;</a>
          </div>
        </div>

        {/* Right Col: Feed */}
        <div class="lg:col-span-2">
           <div class="flex justify-between items-end mb-6">
             <h2 class="text-2xl font-bold text-white">High Priority Intel</h2>
             <span class="text-xs text-gray-500 font-mono uppercase tracking-widest">Score > 5</span>
           </div>
           
           <div class="space-y-4">
           {!recentNodes || recentNodes.length === 0 ? (
             <div class="p-12 text-center text-gray-500 bg-[#1f2833]/10 rounded-3xl border border-[#1f2833] border-dashed">
                <p class="mb-2 text-lg">Your cognitive feed is empty.</p>
                <p class="text-sm">Forward some links to your Telegram bot to populate this view.</p>
             </div>
           ) : (
             recentNodes.map((node) => (
               <a href={`/os/study/${node.id}`} class="block bg-[#1f2833]/30 p-6 rounded-2xl border border-[#1f2833]/80 hover:border-[#66fcf1]/50 hover:bg-[#1f2833]/50 transition-all duration-300">
                  <div class="flex justify-between items-start mb-2 gap-4">
                    <h3 class="text-xl font-bold text-gray-100 leading-snug line-clamp-2">{node.title}</h3>
                    <span class={`flex-shrink-0 text-[10px] font-black uppercase tracking-widest px-3 py-1 rounded-md ${node.importance_score >= 8 ? 'bg-[#66fcf1]/10 text-[#66fcf1] border border-[#66fcf1]/20' : 'bg-black text-gray-400 border border-gray-800'}`}>Score: {node.importance_score}</span>
                  </div>
                  <p class="text-gray-400 text-sm leading-relaxed mb-4 line-clamp-2">{node.summary}</p>
                  
                  <div class="flex gap-2 flex-wrap items-center">
                    {(node.tags || []).map((t: string) => (
                      <span class="bg-black/50 border border-gray-800/50 px-2 py-0.5 rounded text-[10px] text-gray-400 uppercase tracking-wider font-semibold">{t}</span>
                    ))}
                  </div>
               </a>
             ))
           )}
           </div>
        </div>
      </main>
    </div>
  </body>
</html>
